{
  "name": "ai-security-review-agent",
  "displayName": "AI Security Review Agent",
  "description": "AI-powered real-time security scanning for files and workspaces.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiSecurityReviewAgent.scanCurrentFile",
        "title": "Scan Current File",
        "category": "AI Security Review Agent"
      },
      {
        "command": "aiSecurityReviewAgent.scanWorkspace",
        "title": "Scan Workspace",
        "category": "AI Security Review Agent"
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "form-data": "^4.0.4",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "eslint": "^9.39.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
