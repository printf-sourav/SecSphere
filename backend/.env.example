# Backend HTTP port
PORT=5000

# Allowed frontend origin(s) for CORS. Use comma-separated values for multiple origins.
# Example: http://localhost:5173,http://127.0.0.1:5173
FRONTEND_ORIGIN=http://localhost:5173

# Optional Bedrock configuration
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_TIMEOUT_MS=8000

# Optional auto-fix configuration
# Absolute path to project root where /api/fix/apply is allowed to edit files.
AUTO_FIX_PROJECT_ROOT=/home/sourav/Documents/EcellHack

# Max editable file size in bytes for auto-fix safety checks.
MAX_AUTO_FIX_FILE_BYTES=2097152
